{
  "name": "undim-video",
  "private": true,
  "type": "module",
  "scripts": {
    "remove:dist": "rm -rf dist",
    "copy:non-ts": "rsync -a --exclude='*.ts' src/ dist",
    "watch:non-ts": "bun copy:non-ts && bun bin/watch-non-ts.ts",
    "watch:ts": "tsc --project tsconfig.app.json --watch --preserveWatchOutput",
    "watch": "bun --parallel watch:non-ts watch:ts",
    "build:ts": "tsc --project tsconfig.app.json",
    "build:web-ext": "web-ext build --config=web-ext-config.mjs",
    "build": "bun --sequential remove:dist copy:non-ts build:ts build:web-ext",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.13",
    "@types/firefox-webext-browser": "^143.0.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "web-ext": "^10.1.0"
  },
  "prettier": {}
}
