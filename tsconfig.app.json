{
  "extends": "@tsconfig/strictest",
  "exclude": ["node_modules"],
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",

    "module": "esnext",
    "target": "esnext",
    "types": ["@types/firefox-webext-browser"],

    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true
  }
}
