{
  "$schema": "https://json.schemastore.org/chrome-manifest",

  "manifest_version": 3,
  "name": "Undim Video",
  "description": "Removes the dimming effect from video players",
  "version": "0.2.0",

  "icons": {
    "16": "/assets/icon-16.png",
    "32": "/assets/icon-32.png",
    "48": "/assets/icon-48.png",
    "64": "/assets/icon-64.png"
  },

  "host_permissions": [
    "https://www.ardmediathek.de/*",
    "https://www.tagesschau.de/*",
    "https://www.sportschau.de/*",
    "https://www.kika.de/*",

    "https://www.br.de/*",

    "https://www.hr.de/*",
    "https://www.hr1.de/*",
    "https://www.hr2.de/*",
    "https://www.hr3.de/*",
    "https://www.hr4.de/*",
    "https://www.hr-bigband.de/*",
    "https://www.hr-inforadio.de/*",
    "https://www.hr-fernsehen.de/*",
    "https://www.hr-sinfonieorchester.de/*",
    "https://www.hessenschau.de/*",
    "https://www.you-fm.de/*",

    "https://www.mdr.de/*",
    "https://www.mdrjump.de/*",

    "https://www.radiobremen.de/*",
    "https://www.bremeneins.de/*",
    "https://www.bremenzwei.de/*",
    "https://www.bremenvier.de/*",
    "https://www.bremennext.de/*",
    "https://www.butenunbinnen.de/*",

    "https://www.ndr.de/*",

    "https://www.rbb24.de/*",
    "https://www.rbb-online.de/*",
